<UserControl x:Class="MageEditor.Editors.GeometryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MageEditor.Editors"
             d:DataContext="{d:DesignInstance Type=local:MeshRenderer}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Transparent" 
          MouseLeftButtonDown="OnGrid_MouseLeftButtonDown"
          MouseMove="OnGrid_MouseMove"
          MouseLeftButtonUp="OnGrid_MouseLeftButtonUp"
          MouseWheel="OnGrid_MouseWheel"
          MouseRightButtonDown="OnGrid_MouseRightButtonDown"
          MouseRightButtonUp="OnGrid_MouseRightButtonUp">
        <Viewport3D x:Name="viewport" IsHitTestVisible="False">
            <Viewport3D.Camera>
                <PerspectiveCamera FarPlaneDistance="10000" NearPlaneDistance="0.001" FieldOfView="45"
                                   Position="{Binding OffsetCameraPosition}" UpDirection="0,1,0"
                                   LookDirection="{Binding CameraDirection}"/>
            </Viewport3D.Camera>

            <Viewport3D.Children>
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <Model3DGroup>
                            <!--light follows camera -> flashlight pointing at the object we're looking at-->
                            <DirectionalLight Color="{Binding KeyLightColor}" Direction="{Binding CameraDirection}"/>
                            <!--sky light shines from above, therefore it's up direction is negative-->
                            <DirectionalLight Color="{Binding SkyLightColor}" Direction="0,-1,0"/>
                            <!--ground light is the opposite of it-->
                            <DirectionalLight Color="{Binding GroundLightColor}" Direction="0,1,0"/>
                            <AmbientLight Color="{Binding AmbientLightColor}"/>
                        </Model3DGroup>
                    </ModelVisual3D.Content>
                </ModelVisual3D>
            </Viewport3D.Children>
        </Viewport3D>
    </Grid>
</UserControl>
